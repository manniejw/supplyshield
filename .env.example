# SupplyShield environment variables
# Copy to `.env` for local runs (`.env` is gitignored) and NEVER commit real values.
# In CI these are provided as GitHub Actions secrets, not from this file.

# Base44 login used by scan.mjs (base44.auth.loginViaEmailPassword)
BASE44_EMAIL=
BASE44_PASSWORD=

# Optional: only needed if the LLM call is ever switched from Base44's
# InvokeLLM to a direct Anthropic API call. The current scan.mjs does NOT use it.
# ANTHROPIC_API_KEY=
